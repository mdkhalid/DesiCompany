# DesiCompany backend — SAMPLE environment variables
# Copy this file to `.env` and fill in REAL values. NEVER commit `.env`.
# All values below are placeholders — replace before running.

# Database
DB_HOST=127.0.0.1
DB_PORT=5433
DB_USERNAME=desicompany
DB_PASSWORD=changeme
DB_NAME=desicompany
DB_SYNCHRONIZE=false

# JWT secrets (generate each with: openssl rand -hex 32 -> 64-char hex)
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_STRING_0123456789abcdef0123456789abcdef
JWT_REFRESH_SECRET=REPLACE_WITH_64_CHAR_HEX_STRING_0123456789abcdef0123456789abcdef

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# OTP / SMS
OTP_MOCK=true
OTP_MOCK_CODE=123456

# Payment gateway encryption key (AES-256-GCM, 64-char hex = 32 bytes)
PAYMENT_GATEWAY_ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX_STRING_0123456789abcdef0123456789abcdef

# Gateway credentials (stored encrypted at rest)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=REPLACE_ME
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# Push notifications (path to firebase-admin service account JSON; optional)
FIREBASE_CREDENTIALS_PATH=

# Error monitoring (optional)
SENTRY_DSN=

# Runtime
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
