{
  "family": "desicompany-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/desicompany-backend-task",
  "containerDefinitions": [
    {
      "name": "desicompany-backend",
      "image": "<ACCOUNT_ID>.dkr.ecr.ap-south-1.amazonaws.com/desicompany-backend:latest",
      "portMappings": [{ "containerPort": 3000, "protocol": "tcp" }],
      "essential": true,
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -q -O- http://localhost:3000/api/v1/health/live || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "secrets": [
        { "name": "JWT_SECRET", "valueFrom": "arn:aws:secretsmanager:ap-south-1:<ACCOUNT_ID>:secret:desicompany/JWT_SECRET" },
        { "name": "JWT_REFRESH_SECRET", "valueFrom": "arn:aws:secretsmanager:ap-south-1:<ACCOUNT_ID>:secret:desicompany/JWT_REFRESH_SECRET" },
        { "name": "PAYMENT_GATEWAY_ENCRYPTION_KEY", "valueFrom": "arn:aws:secretsmanager:ap-south-1:<ACCOUNT_ID>:secret:desicompany/PAYMENT_GATEWAY_ENCRYPTION_KEY" },
        { "name": "DB_PASSWORD", "valueFrom": "arn:aws:secretsmanager:ap-south-1:<ACCOUNT_ID>:secret:desicompany/DB_PASSWORD" },
        { "name": "AWS_SECRET_ACCESS_KEY", "valueFrom": "arn:aws:secretsmanager:ap-south-1:<ACCOUNT_ID>:secret:desicompany/AWS_SECRET_ACCESS_KEY" },
        { "name": "TWILIO_AUTH_TOKEN", "valueFrom": "arn:aws:secretsmanager:ap-south-1:<ACCOUNT_ID>:secret:desicompany/TWILIO_AUTH_TOKEN" },
        { "name": "RAZORPAY_KEY_SECRET", "valueFrom": "arn:aws:secretsmanager:ap-south-1:<ACCOUNT_ID>:secret:desicompany/RAZORPAY_KEY_SECRET" },
        { "name": "STRIPE_SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:ap-south-1:<ACCOUNT_ID>:secret:desicompany/STRIPE_SECRET_KEY" }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3000" },
        { "name": "API_PREFIX", "value": "/api/v1" },
        { "name": "DB_HOST", "value": "<RDS_ENDPOINT>.rds.amazonaws.com" },
        { "name": "DB_PORT", "value": "5432" },
        { "name": "DB_USERNAME", "value": "desicompany" },
        { "name": "DB_NAME", "value": "desicompany" },
        { "name": "DB_SYNCHRONIZE", "value": "false" },
        { "name": "REDIS_HOST", "value": "<REDIS_ENDPOINT>.cache.amazonaws.com" },
        { "name": "REDIS_PORT", "value": "6379" },
        { "name": "CORS_ALLOWED_ORIGINS", "value": "https://admin.desicompany-api.com" },
        { "name": "OTP_MOCK", "value": "false" },
        { "name": "STORAGE_PROVIDER", "value": "s3" },
        { "name": "S3_BUCKET", "value": "desicompany-uploads" },
        { "name": "AWS_REGION", "value": "ap-south-1" },
        { "name": "AWS_ACCESS_KEY_ID", "value": "<S3_USER_ACCESS_KEY_ID>" },
        { "name": "S3_PUBLIC_URL", "value": "https://desicompany-uploads.s3.ap-south-1.amazonaws.com" },
        { "name": "TWILIO_ACCOUNT_SID", "value": "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx" },
        { "name": "TWILIO_PHONE_NUMBER", "value": "+919876543210" },
        { "name": "PAYMENT_GATEWAY", "value": "razorpay" },
        { "name": "RAZORPAY_KEY_ID", "value": "rzp_live_xxxxxxxxxxxxxx" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/desicompany-backend",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
