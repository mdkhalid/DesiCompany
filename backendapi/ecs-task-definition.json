{
  "family": "desicompany-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::469664763801:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::469664763801:role/desicompany-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "desicompany-backend",
      "image": "469664763801.dkr.ecr.ap-south-1.amazonaws.com/desicompany-backend:latest",
      "portMappings": [{ "containerPort": 3000, "protocol": "tcp" }],
      "essential": true,
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -q -O- http://localhost:3000/api/v1/health/live || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "secrets": [
        { "name": "DB_HOST", "valueFrom": "arn:aws:secretsmanager:ap-south-1:469664763801:secret:desicompany/production-SiWzHS:DB_HOST::" },
        { "name": "DB_PASSWORD", "valueFrom": "arn:aws:secretsmanager:ap-south-1:469664763801:secret:desicompany/production-SiWzHS:DB_PASSWORD::" },
        { "name": "JWT_SECRET", "valueFrom": "arn:aws:secretsmanager:ap-south-1:469664763801:secret:desicompany/production-SiWzHS:JWT_SECRET::" },
        { "name": "JWT_REFRESH_SECRET", "valueFrom": "arn:aws:secretsmanager:ap-south-1:469664763801:secret:desicompany/production-SiWzHS:JWT_REFRESH_SECRET::" },
        { "name": "PAYMENT_GATEWAY_ENCRYPTION_KEY", "valueFrom": "arn:aws:secretsmanager:ap-south-1:469664763801:secret:desicompany/production-SiWzHS:PAYMENT_GATEWAY_ENCRYPTION_KEY::" },
        { "name": "REDIS_HOST", "valueFrom": "arn:aws:secretsmanager:ap-south-1:469664763801:secret:desicompany/production-SiWzHS:REDIS_HOST::" },
        { "name": "AWS_ACCESS_KEY_ID", "valueFrom": "arn:aws:secretsmanager:ap-south-1:469664763801:secret:desicompany/production-SiWzHS:AWS_ACCESS_KEY_ID::" },
        { "name": "AWS_SECRET_ACCESS_KEY", "valueFrom": "arn:aws:secretsmanager:ap-south-1:469664763801:secret:desicompany/production-SiWzHS:AWS_SECRET_ACCESS_KEY::" },
        { "name": "TWILIO_ACCOUNT_SID", "valueFrom": "arn:aws:secretsmanager:ap-south-1:469664763801:secret:desicompany/production-SiWzHS:TWILIO_ACCOUNT_SID::" },
        { "name": "TWILIO_AUTH_TOKEN", "valueFrom": "arn:aws:secretsmanager:ap-south-1:469664763801:secret:desicompany/production-SiWzHS:TWILIO_AUTH_TOKEN::" },
        { "name": "TWILIO_PHONE_NUMBER", "valueFrom": "arn:aws:secretsmanager:ap-south-1:469664763801:secret:desicompany/production-SiWzHS:TWILIO_PHONE_NUMBER::" }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3000" },
        { "name": "API_PREFIX", "value": "/api/v1" },
        { "name": "DB_NAME", "value": "desicompany" },
        { "name": "DB_SYNCHRONIZE", "value": "false" },
        { "name": "DB_USERNAME", "value": "desicompany" },
        { "name": "DB_PORT", "value": "5432" },
        { "name": "DB_SSL", "value": "true" },
        { "name": "REDIS_PORT", "value": "6379" },
        { "name": "CORS_ALLOWED_ORIGINS", "value": "*" },
        { "name": "OTP_MOCK", "value": "false" },
        { "name": "STORAGE_PROVIDER", "value": "s3" },
        { "name": "S3_BUCKET", "value": "desicompany-uploads-prod" },
        { "name": "AWS_REGION", "value": "ap-south-1" },
        { "name": "S3_PUBLIC_URL", "value": "https://desicompany-uploads-prod.s3.ap-south-1.amazonaws.com" },
        { "name": "PAYMENT_GATEWAY", "value": "razorpay" },
        { "name": "COMMISSION_TYPE", "value": "percentage" },
        { "name": "COMMISSION_VALUE", "value": "10" },
        { "name": "LOG_LEVEL", "value": "info" },
        { "name": "METRICS_ENABLED", "value": "true" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/desicompany-backend",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
