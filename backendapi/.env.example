# Server
PORT=3000
NODE_ENV=development
API_PREFIX=/api/v1

# Database
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=desicompany
DB_PASSWORD=<generate-strong-password>
DB_NAME=desicompany
DB_SYNCHRONIZE=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=<64-char-hex-secret>
JWT_EXPIRATION_MINUTES=1440
JWT_REFRESH_SECRET=<64-char-hex-secret>
JWT_REFRESH_EXPIRATION=30d

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# OTP / SMS
# Set OTP_MOCK=true for development (uses OTP_MOCK_CODE instead of sending SMS)
# Set OTP_MOCK=false for production (requires Twilio credentials)
OTP_MOCK=true
OTP_MOCK_CODE=123456
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Payment Gateway
PAYMENT_GATEWAY=razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# File Upload
UPLOAD_DEST=./uploads
MAX_FILE_SIZE=5242880

# Storage Provider (local or s3)
STORAGE_PROVIDER=local
APP_URL=http://localhost:3000
# S3/R2 Configuration (only needed when STORAGE_PROVIDER=s3)
# S3_BUCKET=
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=
# CDN_URL=

# Commission
COMMISSION_TYPE=percentage
COMMISSION_VALUE=10

# Payment Gateway Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
PAYMENT_GATEWAY_ENCRYPTION_KEY=<64-char-hex-key>

# Logging
LOG_LEVEL=info

# Sentry (set DSN for production error tracking)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Metrics (Prometheus)
METRICS_ENABLED=true

# Error Logs
ERROR_LOG_RETENTION_DAYS=30
ERROR_LOG_INCLUDE_STACK_4XX=false

# Error Spike Alerting (set SLACK_WEBHOOK_URL to enable)
ERROR_SPIKE_WINDOW_MINUTES=5
ERROR_SPIKE_THRESHOLD=50
ERROR_SPIKE_SILENCE_MINUTES=15
SLACK_WEBHOOK_URL=
