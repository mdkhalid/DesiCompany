# Server
PORT=3000
NODE_ENV=development
API_PREFIX=/api/v1

# Database
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=desicompany
DB_PASSWORD=desicompany123
DB_NAME=desicompany

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT — GENERATE WITH: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION_MINUTES=15
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRATION=7d

# CORS (comma-separated origins, leave empty for dev, MUST set in production)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# OTP / SMS
OTP_MOCK=true
OTP_MOCK_CODE=123456
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Payment Gateway (Razorpay for India)
PAYMENT_GATEWAY=razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# File Upload
UPLOAD_DEST=./uploads
MAX_FILE_SIZE=5242880

# Commission (global fallback)
COMMISSION_TYPE=percentage
COMMISSION_VALUE=10

# Payment Gateway Encryption (64-char hex, generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
PAYMENT_GATEWAY_ENCRYPTION_KEY=CHANGE_ME_TO_64_CHAR_HEX_STRING
